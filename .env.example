# ─── Railway / Production ───────────────────────
# PORT=8000                    # Railway sets this automatically
# FRONTEND_URL=https://your-app.up.railway.app

# ─── football-data.org ──────────────────────────
# Free key at https://www.football-data.org/
FOOTBALL_API_KEY=your_key_here

# ─── Reddit API ─────────────────────────────────
# Create app at https://www.reddit.com/prefs/apps (type: script)
# REDDIT_CLIENT_ID=your_client_id
# REDDIT_CLIENT_SECRET=your_client_secret

# ─── Twitter/X ──────────────────────────────────
# Option 1: Cookies (recommended, more stable)
# Get auth_token and ct0 from browser DevTools → Application → Cookies → x.com
# TWITTER_COOKIES="auth_token=xxx; ct0=yyy"
#
# Option 2: Credentials (less stable, needs email IMAP access)
# TWITTER_USERNAME=your_username
# TWITTER_PASSWORD=your_password
# TWITTER_EMAIL=your_email
# TWITTER_EMAIL_PASSWORD=your_email_password
